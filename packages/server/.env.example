# Notre base locale (SQL Server)
DATABASE_URL="sqlserver://HOST:1433;database=DB_NAME;user=USER;password=PASSWORD;trustServerCertificate=true"

# BrainOpx - base principale (lecture seule)
BRAINOPX_HOST=HOST
BRAINOPX_DATABASE=DB_NAME
BRAINOPX_USER=USER
BRAINOPX_PASSWORD=PASSWORD
BRAINOPX_ENCRYPT=false
BRAINOPX_TRUST_CERT=true

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM="Relance Client <noreply@example.com>"
