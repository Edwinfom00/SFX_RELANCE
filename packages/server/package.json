{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test:reset": "tsx scripts/reset-test-dates.ts",
    "test:reset-1h": "tsx scripts/reset-test-dates.ts --hours 1",
    "test:reset-24h": "tsx scripts/reset-test-dates.ts --hours 24",
    "test:reset-48h": "tsx scripts/reset-test-dates.ts --hours 48"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "dotenv": "^16.0.0",
    "mssql": "^12.3.1",
    "node-windows": "^1.0.0-beta.8",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "bcryptjs": "^3.0.3",
    "esbuild": "^0.28.0",
    "prisma": "^6.0.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
